{
  "name": "bitohelp",
  "version": "0.0.1",
  "description": "A Quasar Project",
  "productName": "Quasar App",
  "author": "",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,vue,css,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare",
    "backend": "cd backend && .\\venv\\Scripts\\python manage.py runserver",
    "start:all": "concurrently \"pnpm run backend\" \"pnpm run dev\" --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\""
  },
  "dependencies": {
    "@quasar/extras": "^1.16.4",
    "@walletconnect/core": "^2.19.0",
    "@walletconnect/modal": "^2.7.0",
    "@walletconnect/sign-client": "^2.19.0",
    "axios": "^1.2.1",
    "cashaddrjs": "^0.4.4",
    "cashscript": "^0.12.1",
    "chart.js": "^4.5.1",
    "lottie-web": "^5.13.0",
    "mainnet-js": "^3.1.7",
    "pinia": "^3.0.1",
    "plotly.js-gl3d-dist-min": "^3.4.0",
    "quasar": "^2.16.0",
    "vue": "^3.5.22",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@quasar/app-vite": "^2.1.0",
    "@vue/eslint-config-prettier": "^10.1.0",
    "autoprefixer": "^10.4.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.4.0",
    "postcss": "^8.4.14",
    "prettier": "^3.3.3",
    "vite-plugin-checker": "^0.11.0",
    "vue-eslint-parser": "^10.2.0"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
